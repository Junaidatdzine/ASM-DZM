# Web app configuration. Copy to `.env.local` and fill in your Firebase
# project's web app config. Do NOT commit the real `.env.local`.
# These VITE_ values are embedded in the client bundle at build time.

VITE_FB_API_KEY=your-firebase-web-api-key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_STORAGE_BUCKET=your-project.appspot.com
VITE_FB_MESSAGING_SENDER_ID=000000000000
VITE_FB_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# Set to "true" to point the web app at local Firebase emulators (dev only).
VITE_USE_EMULATORS=false
