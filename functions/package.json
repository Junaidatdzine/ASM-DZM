{
  "name": "@asm/functions",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud Functions — all ASC + Gemini traffic and privileged writes",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --packages=external --alias:@asm/shared=../shared/src --outfile=lib/index.js --sourcemap=inline",
    "build:watch": "pnpm build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.16.0",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
