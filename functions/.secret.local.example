# Local secret overrides for the Firebase emulator.
# Copy to `.secret.local` and fill in real values. Do NOT commit the real file.
# In production these are provided via Firebase Secret Manager (defineSecret).

# Master key used to encrypt/decrypt App Store Connect credentials.
ASC_MASTER_KEY=your-asc-master-key

# Resend API key for sending report emails (https://resend.com).
RESEND_API_KEY=re_your_resend_api_key
